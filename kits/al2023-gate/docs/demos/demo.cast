[8.449153, "o", "  [medium] line 5: yum-to-dnf\r\n"]
[8.4492, "o", "    yum update -y\r\n"]
[8.44923, "o", "    → `yum` still works as a compat alias on AL2023 but is deprecated.\r\n"]
[8.449261, "o", "    ✎ Replace `yum` with `dnf` for forward compatibility.\r\n"]
