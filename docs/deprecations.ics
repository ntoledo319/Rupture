BEGIN:VEVENT
SUMMARY:AWS Deprecation: Lambda Node.js 20 Phase 1
DTSTART;VALUE=DATE:20260430
DTEND;VALUE=DATE:20260501
DTSTAMP:20260503T050700Z
UID:lambda-node.js-20-phase-1@rupture
CREATED:20260503T050700Z
DESCRIPTION:Lambda functions using Node.js 20 runtime will fail to update.
  Phase 1: CreateFunction and UpdateFunctionConfiguration blocked.
URL:https://docs.aws.amazon.com/lambda/latest/dg/lambda-runtimes.html
BEGIN:VALARM
ACTION:DISPLAY
DESCRIPTION:30 days until Lambda Node.js 20 Phase 1 deprecation
TRIGGER:-P30D
END:VALARM
END:VEVENT
BEGIN:VEVENT
