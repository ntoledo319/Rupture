<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ deprecation.name }} migration guide — deadline {{ deprecation.date }} | EOLkits</title>
    <meta name="description" content="{{ deprecation.name }} ends {{ deprecation.date }} ({{ urgency.label }}). {{ deprecation.service }}. {{ deprecation.breaking_changes|length }} breaking changes, exact migration facts, and a free CLI ({{ deprecation.kit or 'EOLkits' }}) to scan, codemod, and ship before the deadline.">
    <meta name="keywords" content="{{ deprecation.name }}, AWS deprecation, {{ deprecation.service }}, {{ deprecation.tags|join(', ') }}, migration, end of life, {{ deprecation.date }}">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ site_url }}/migrate/{{ deprecation.slug }}/">
    <link rel="stylesheet" href="/style.css">
    <link rel="alternate" type="text/calendar" title="AWS Deprecation Deadlines (EOLkits)" href="/deprecations.ics">

    <!-- Open Graph -->
    <meta property="og:title" content="{{ deprecation.name }} — AWS deprecation migration guide (deadline {{ deprecation.date }})">
    <meta property="og:description" content="{{ deprecation.description }}">
    <meta property="og:url" content="{{ site_url }}/migrate/{{ deprecation.slug }}/">
    <meta property="og:type" content="article">
    <meta property="og:site_name" content="EOLkits">
    <meta property="article:published_time" content="{{ now }}">
    <meta property="article:modified_time" content="{{ now }}">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ deprecation.name }} — Migration Guide">
    <meta name="twitter:description" content="Deadline {{ deprecation.date }} ({{ urgency.days_until }} days). {{ deprecation.breaking_changes|length }} breaking changes, cited from AWS docs.">

    <!-- Schema.org: TechArticle (every fact cited to deprecation.url) -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "TechArticle",
        "headline": {{ (deprecation.name ~ " — AWS Deprecation Migration Guide")|tojson }},
        "description": {{ deprecation.description|tojson }},
        "datePublished": {{ now|tojson }},
        "dateModified": {{ now|tojson }},
        "proficiencyLevel": "Expert",
        "keywords": {{ (deprecation.tags|join(", "))|tojson }},
        "citation": {{ deprecation.url|tojson }},
        "author": { "@type": "Organization", "name": "EOLkits", "url": "{{ site_url }}" },
        "publisher": {
            "@type": "Organization",
            "name": "EOLkits",
            "url": "{{ site_url }}"
        },
        "about": {
            "@type": "SoftwareApplication",
            "name": {{ deprecation.service|tojson }},
            "applicationCategory": "CloudComputing"
        },
        "mainEntityOfPage": "{{ site_url }}/migrate/{{ deprecation.slug }}/"
    }
    </script>

    <!-- Schema.org: BreadcrumbList -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site_url }}/" },
            { "@type": "ListItem", "position": 2, "name": "AWS deprecations", "item": "{{ site_url }}/migrate/" },
            { "@type": "ListItem", "position": 3, "name": {{ deprecation.name|tojson }}, "item": "{{ site_url }}/migrate/{{ deprecation.slug }}/" }
        ]
    }
    </script>

    <!-- Schema.org: FAQPage (answers are deterministic, grounded in the YAML) -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            {
                "@type": "Question",
                "name": "When is the {{ deprecation.name }} deadline?",
                "acceptedAnswer": { "@type": "Answer", "text": {{ ("The deadline is " ~ deprecation.date ~ ". " ~ deprecation.description ~ " Source: " ~ deprecation.url)|tojson }} }
            },
            {
                "@type": "Question",
                "name": "What breaks when {{ deprecation.name }} reaches end of life?",
                "acceptedAnswer": { "@type": "Answer", "text": {{ ((deprecation.breaking_changes|join("; ")) ~ ". Source: " ~ deprecation.url)|tojson }} }
            },
            {
                "@type": "Question",
                "name": "Which AWS services are affected by {{ deprecation.name }}?",
                "acceptedAnswer": { "@type": "Answer", "text": {{ ("Affected services: " ~ deprecation.service ~ ". Affected resource types: " ~ deprecation.resource_type ~ ". Source: " ~ deprecation.url)|tojson }} }
            },
            {
                "@type": "Question",
                "name": "Is there a free tool to migrate off {{ deprecation.name }}?",
                "acceptedAnswer": { "@type": "Answer", "text": {{ (("Yes. " ~ (deprecation.kit or "EOLkits") ~ " is an MIT-licensed CLI that scans, codemods, and patches IaC for this deprecation. Paid Audit ($" ~ pricing.audit_pdf.base|string ~ ") and Migration Pack ($" ~ pricing.migration_pack.base|string ~ ") tiers add automated reports and PRs.") if deprecation.kit else ("EOLkits provides cited migration guidance and paid Audit / Migration Pack tiers for this deprecation."))|tojson }} }
            }
        ]
    }
    </script>
</head>
<body class="migrate-page">

<header class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand"><span class="brand-mark">▸</span> EOLkits</a>
    <nav>
      <a href="/migrate/">Deadlines</a>
      <a href="/#pricing">Pricing</a>
      <a href="/deprecations.ics">Calendar</a>
      <a href="https://github.com/ntoledo319/EOLkits" class="btn-ghost">GitHub</a>
    </nav>
  </div>
</header>

<main class="container article">
    <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> / <a href="/migrate/">AWS deprecations</a> / <span>{{ deprecation.name }}</span>
    </nav>

    <article>
        <div class="deadline-banner {{ urgency.tier }}">
            <span class="severity-badge severity-{{ deprecation.severity }}">{{ deprecation.severity }}</span>
            <h1>{{ deprecation.name }}</h1>
            <p class="banner-sub">{{ deprecation.service }} — end-of-life deadline</p>
            <div class="countdown" data-deadline="{{ deprecation.date }}">{{ deprecation.date }}</div>
            <p class="urgency">{{ urgency.headline }}</p>
        </div>

        <section>
            <h2>What is being deprecated?</h2>
            <p>{{ deprecation.description }}</p>
            <table class="facts">
                <tr><th>Deadline</th><td><strong>{{ deprecation.date }}</strong> ({{ urgency.days_until }} days from build date {{ now[:10] }})</td></tr>
                <tr><th>Service</th><td>{{ deprecation.service }}</td></tr>
                <tr><th>Affected resources</th><td><code>{{ deprecation.resource_type }}</code></td></tr>
                <tr><th>Severity</th><td><span class="severity-badge severity-{{ deprecation.severity }}">{{ deprecation.severity }}</span></td></tr>
                {% if deprecation.kit %}<tr><th>Migration kit</th><td><code>{{ deprecation.kit }}</code> (free, MIT)</td></tr>{% endif %}
                <tr><th>Primary source</th><td><a href="{{ deprecation.url }}" target="_blank" rel="noopener nofollow">{{ deprecation.url }}</a></td></tr>
            </table>
            <p class="cite-note">Every fact on this page is taken from the cited AWS / upstream source above. EOLkits ships no claim without a primary source.</p>
        </section>

        <section class="breaking-changes">
            <h2>Breaking changes</h2>
            <p>The following changes take effect at or before the {{ deprecation.date }} deadline. <a href="{{ deprecation.url }}" target="_blank" rel="noopener nofollow">[source]</a></p>
            <ul>
                {% for change in deprecation.breaking_changes %}
                <li>{{ change }}</li>
                {% endfor %}
            </ul>
        </section>

        {% if deprecation.kit %}
        <section>
            <h2>Migrate with the free <code>{{ deprecation.kit }}</code> CLI</h2>
            <p>The MIT-licensed CLI runs the same five-step migration on every deprecation: scan, fix, test, deploy canary, rollback. No AWS credentials needed for the offline fixture run.</p>
            <div class="migration-steps">
                <div class="step">
                    <h4>Scan your infrastructure</h4>
                    <p>Enumerate every resource still on the deprecated runtime.</p>
                    <pre class="code-block"><code>{% if deprecation.kit == 'lambda-lifeline' %}npm install -g {{ deprecation.kit }}
{{ deprecation.kit }} scan --region us-east-1{% else %}pip install {{ deprecation.kit }}
{{ deprecation.kit }} scan --region us-east-1{% endif %}</code></pre>
                </div>
                <div class="step">
                    <h4>Review findings by severity × blast radius</h4>
                    <p>The scan prints a table ordered by how much breaks and how soon.</p>
                </div>
                <div class="step">
                    <h4>Apply codemods (dry-run first)</h4>
                    <p>Mechanically-safe rewrites for the breaking changes above. Everything ambiguous is flagged, not auto-changed.</p>
                    <pre class="code-block"><code>{{ deprecation.kit }} apply --dry-run
{{ deprecation.kit }} apply</code></pre>
                </div>
                <div class="step">
                    <h4>Deploy with a staged canary + auto-rollback</h4>
                    <p>5% → 25% → 50% → 100%, with a CloudWatch-alarm trip reverting instantly.</p>
                </div>
            </div>
        </section>
        {% endif %}

        <section class="conversion">
            <h2>Want it done for you before {{ deprecation.date }}?</h2>
            <div class="pricing-grid-2">
                <div class="pricing-card">
                    <h3>Audit PDF</h3>
                    <div class="price">${{ urgency.audit_price }}{% if urgency.audit_price != pricing.audit_pdf.base %} <span class="per">surge — base ${{ pricing.audit_pdf.base }}</span>{% endif %}</div>
                    <p>Hash-anchored deterministic report scoring every {{ deprecation.name }} finding by severity × blast-radius, with a roll-forward roadmap and cost-of-not-fixing estimate. Delivered by email in 5 minutes.</p>
                    <a href="{{ urgency.audit_link }}" class="btn-primary">Order Audit — ${{ urgency.audit_price }}</a>
                </div>
                <div class="pricing-card featured">
                    <h3>Migration Pack</h3>
                    <div class="price">${{ "{:,}".format(pricing.migration_pack.base) }}</div>
                    <p>A real PR opened on your repo: {{ deprecation.kit or 'EOLkits' }} codemods + IaC patches + canary plan + rollback. <strong>Auto-refund if your CI fails within 7 days.</strong></p>
                    <a href="{{ pricing.migration_pack.link }}" class="btn-primary">Get Migration Pack — ${{ "{:,}".format(pricing.migration_pack.base) }}</a>
                    <a href="/pack/" class="btn-outline">How it works</a>
                </div>
            </div>
        </section>

        {% if related %}
        <section class="related">
            <h2>Related AWS deprecations</h2>
            <p>Same service family or migration kit — each with cited deadlines and breaking changes.</p>
            <ul class="related-list">
                {% for rel in related %}
                <li>
                    <a href="/migrate/{{ rel.slug }}/">{{ rel.name }}</a>
                    <span class="rel-meta">— deadline <strong>{{ rel.date }}</strong> · {{ rel.severity }}{% if rel.kit %} · <code>{{ rel.kit }}</code>{% endif %}</span>
                </li>
                {% endfor %}
            </ul>
            <p><a href="/migrate/" class="kit-link">See all tracked AWS deadlines →</a> · <a href="/deprecations.ics" class="kit-link">Subscribe to the deadline calendar (.ics) →</a></p>
        </section>
        {% endif %}

        <section class="faq" id="faq">
            <h2>Frequently asked questions</h2>
            <details open>
                <summary>When is the {{ deprecation.name }} deadline?</summary>
                <p>{{ deprecation.date }}. {{ deprecation.description }} <a href="{{ deprecation.url }}" target="_blank" rel="noopener nofollow">[AWS source]</a></p>
            </details>
            <details>
                <summary>What happens if I don't migrate by {{ deprecation.date }}?</summary>
                <p>The breaking changes listed above take effect: {{ deprecation.breaking_changes|join("; ") }}. <a href="{{ deprecation.url }}" target="_blank" rel="noopener nofollow">[source]</a></p>
            </details>
            <details>
                <summary>Which AWS services does this affect?</summary>
                <p>{{ deprecation.service }} — specifically <code>{{ deprecation.resource_type }}</code> resources.</p>
            </details>
            {% if deprecation.kit %}
            <details>
                <summary>Is there a free way to migrate?</summary>
                <p>Yes — the <code>{{ deprecation.kit }}</code> CLI is MIT-licensed and free for unlimited runs. The paid Audit (${{ pricing.audit_pdf.base }}) and Migration Pack (${{ "{:,}".format(pricing.migration_pack.base) }}) tiers add a hash-anchored report and an automated PR with a CI-failure refund guarantee.</p>
            </details>
            {% endif %}
        </section>
    </article>
</main>

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="brand"><span class="brand-mark">▸</span> EOLkits</div>
        <p class="muted">Every AWS deprecation deadline deserves a kit.</p>
      </div>
      <div>
        <h5>Deadlines</h5>
        <a href="/migrate/">All AWS deprecations</a><br>
        <a href="/deprecations.ics">Deadline calendar (.ics)</a>
      </div>
      <div>
        <h5>Resources</h5>
        <a href="https://github.com/ntoledo319/EOLkits">GitHub</a><br>
        <a href="/#pricing">Pricing</a><br>
        <a href="/legal/terms">Terms</a> · <a href="/legal/privacy">Privacy</a>
      </div>
    </div>
    <div class="muted small">© 2026 EOLkits · MIT-licensed kits · facts cited from primary sources</div>
  </div>
</footer>

<script>
    // Live countdown from the cited deadline date (display-only; the canonical
    // fact is the server-rendered date above).
    (function () {
        var el = document.querySelector('.countdown');
        if (!el) return;
        var deadline = new Date(el.dataset.deadline + 'T00:00:00Z');
        var diff = deadline - new Date();
        if (diff > 0) {
            var days = Math.floor(diff / 86400000);
            el.textContent = el.dataset.deadline + ' · ' + days + ' days left';
        } else {
            el.textContent = el.dataset.deadline + ' · deadline passed';
        }
    })();
</script>
</body>
</html>
