<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">

    <!-- Main pages -->
    <url>
        <loc>https://ntoledo319.github.io/EOLkits/</loc>
        <lastmod>{{ now }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>1.0</priority>
    </url>

    <url>
        <loc>https://ntoledo319.github.io/EOLkits/migrate/</loc>
        <lastmod>{{ now }}</lastmod>
        <changefreq>daily</changefreq>
        <priority>0.9</priority>
    </url>

    <url>
        <loc>https://ntoledo319.github.io/EOLkits/audit/</loc>
        <lastmod>{{ now }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.9</priority>
    </url>

    <url>
        <loc>https://ntoledo319.github.io/EOLkits/pack/</loc>
        <lastmod>{{ now }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.9</priority>
    </url>

    <!-- Pricing -->
    <url>
        <loc>https://ntoledo319.github.io/EOLkits/#pricing</loc>
        <lastmod>{{ now }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.8</priority>
    </url>

    <!-- Deprecation migration guides (one per cited deprecation in deprecations.yml) -->
    {% for dep in deprecations %}
    <url>
        <loc>https://ntoledo319.github.io/EOLkits/migrate/{{ dep.slug }}/</loc>
        <lastmod>{{ now }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.8</priority>
    </url>
    {% endfor %}

    <!-- Legal pages -->
    <url>
        <loc>https://ntoledo319.github.io/EOLkits/legal/terms</loc>
        <lastmod>{{ now }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.5</priority>
    </url>

    <url>
        <loc>https://ntoledo319.github.io/EOLkits/legal/privacy</loc>
        <lastmod>{{ now }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.5</priority>
    </url>

    <url>
        <loc>https://ntoledo319.github.io/EOLkits/legal/SECURITY</loc>
        <lastmod>{{ now }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.5</priority>
    </url>

    <!-- Status page -->
    <url>
        <loc>https://ntoledo319.github.io/EOLkits/status/</loc>
        <lastmod>{{ now }}</lastmod>
        <changefreq>hourly</changefreq>
        <priority>0.6</priority>
    </url>

</urlset>
