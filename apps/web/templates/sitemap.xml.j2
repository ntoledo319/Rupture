<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

    <!-- Core pages (root-relative to the canonical host) -->
    <url><loc>{{ site_url }}/</loc><lastmod>{{ now }}</lastmod><changefreq>weekly</changefreq><priority>1.0</priority></url>
    <url><loc>{{ site_url }}/migrate/</loc><lastmod>{{ now }}</lastmod><changefreq>daily</changefreq><priority>0.9</priority></url>
    <url><loc>{{ site_url }}/audit/</loc><lastmod>{{ now }}</lastmod><changefreq>weekly</changefreq><priority>0.9</priority></url>
    <url><loc>{{ site_url }}/pack/</loc><lastmod>{{ now }}</lastmod><changefreq>weekly</changefreq><priority>0.9</priority></url>
    <url><loc>{{ site_url }}/license/</loc><lastmod>{{ now }}</lastmod><changefreq>weekly</changefreq><priority>0.7</priority></url>
    <url><loc>{{ site_url }}/drift/</loc><lastmod>{{ now }}</lastmod><changefreq>weekly</changefreq><priority>0.7</priority></url>
    <url><loc>{{ site_url }}/partners/</loc><lastmod>{{ now }}</lastmod><changefreq>monthly</changefreq><priority>0.6</priority></url>
    <url><loc>{{ site_url }}/vs/</loc><lastmod>{{ now }}</lastmod><changefreq>monthly</changefreq><priority>0.6</priority></url>
    {% for c in competitors %}
    <url><loc>{{ site_url }}/vs/{{ c.slug }}/</loc><lastmod>{{ now }}</lastmod><changefreq>monthly</changefreq><priority>0.5</priority></url>
    {% endfor %}

    <!-- Deprecation migration guides (one per cited deprecation in deprecations.yml) -->
    {% for dep in deprecations %}
    <url><loc>{{ site_url }}/migrate/{{ dep.slug }}/</loc><lastmod>{{ now }}</lastmod><changefreq>weekly</changefreq><priority>0.8</priority></url>
    {% endfor %}

    <!-- Content + system pages -->
    <url><loc>{{ site_url }}/blog/</loc><lastmod>{{ now }}</lastmod><changefreq>weekly</changefreq><priority>0.5</priority></url>
    <url><loc>{{ site_url }}/status/</loc><lastmod>{{ now }}</lastmod><changefreq>hourly</changefreq><priority>0.6</priority></url>

    <!-- Legal (served as real HTML files) -->
    <url><loc>{{ site_url }}/legal/terms.html</loc><lastmod>{{ now }}</lastmod><changefreq>monthly</changefreq><priority>0.4</priority></url>
    <url><loc>{{ site_url }}/legal/privacy.html</loc><lastmod>{{ now }}</lastmod><changefreq>monthly</changefreq><priority>0.4</priority></url>
    <url><loc>{{ site_url }}/legal/dpa.html</loc><lastmod>{{ now }}</lastmod><changefreq>monthly</changefreq><priority>0.4</priority></url>
    <url><loc>{{ site_url }}/legal/SECURITY.html</loc><lastmod>{{ now }}</lastmod><changefreq>monthly</changefreq><priority>0.4</priority></url>

</urlset>
